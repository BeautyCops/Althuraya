# نسخ هذا الملف إلى `.env` للتطوير المحلي (لا تشاركي القيم الحقيقية في الإنتاج).

# أصل الموقع بدون شرطة أخيرة — لروابط og:image المطلقة عند مشاركة الرابط (واتساب، إكس، …).
# مثال مع نطاق GitHub Pages: https://USER.github.io/REPO
# VITE_SITE_URL=https://althuraya.store

# لتشغيل قاعدة محلية: من جذر المشروع `docker compose up -d` ثم استخدم السطر التالي (المنفذ 5433 يتجنب تعارض Postgres نافذ المنفّذ على 5432):
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/althuraya

# أو بدون Docker Compose:
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/althuraya

# عنوانات مثل `.railway.internal`: غالبًا بدون TLS في الكود. لإيقاف TLS يدويًا (مثل Postgres محلي مع NODE_ENV=production):
# DATABASE_SSL_DISABLE=1

# مهلة تشغيل الترحيل عند الإقلاع (بالملّي ثانية، الافتراضي 120000).
# MIGRATE_BOOT_TIMEOUT_MS=120000

# لتشخيص Railway فقط: تجاوز تشغيل الهجرة عند الإقلاع (لا تُتركي مفعّلة في الإنتاج).
# SKIP_DB_MIGRATE_ON_BOOT=1

# اختياري: مفتاح 32 بايتاً (hex 64 حرفاً أو base64) لتشفير الحقول الحساسة في الخادم (مثل display_name_encrypted).
# DATA_ENCRYPTION_KEY=

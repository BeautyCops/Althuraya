{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "startCommand": "/bin/sh -c \"exec ./node_modules/.bin/serve dist/client -s --no-clipboard --listen tcp://0.0.0.0:$PORT\""
  }
}

# انسخي هذا الملف إلى ".env" واملئي القيم.
# احصلي على الـ Client ID و Client Secret من:
# https://www.canva.com/developers/integrations/connect-api

CANVA_CLIENT_ID=OC-AZ23fG0IC40H
CANVA_CLIENT_SECRET=cnvca...ضعي_السر_هنا

# لا تغيّري هذا إلا إذا غيّرتِ المنفذ. يجب إضافة نفس العنوان بالضبط
# في صفحة "Authentication" داخل بوابة مطوري Canva كـ Redirect URL.
CANVA_REDIRECT_URI=http://127.0.0.1:3000/oauth/callback

# (اختياري) الصلاحيات المطلوبة مفصولة بمسافات. إن لم تضيفي سطر CANVA_SCOPES،
# يطلب السكربت design:meta:read فقط (لتفادي invalid_scope). بعد تفعيل باقي
# الصلاحيات في Scopes + الحفظ، أضيفي:
# CANVA_SCOPES=design:meta:read design:content:read design:content:write folder:read folder:write asset:read asset:write
